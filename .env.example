DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/agentic_rag_workbench
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=development
DEPLOYMENT_MODE=local
CORS_ALLOWED_ORIGINS=*
ENABLE_DOCS=true
ENABLE_DEMO_ENDPOINTS=true
REQUIRE_DEMO_API_KEY=false
DEMO_API_KEY=
DEMO_API_KEY_HEADER=X-Demo-API-Key
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60
MAX_REQUEST_BODY_BYTES=1048576
LOG_LEVEL=INFO
CHROMA_HOST=chroma
CHROMA_PORT=8000
CHROMA_COLLECTION=business_documents
EMBEDDING_PROVIDER=mock
LLM_PROVIDER=mock
LLM_MODEL=mock-trace-generator
LLM_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
CHUNK_SIZE=800
CHUNK_OVERLAP=120
MAX_DOCUMENT_UPLOAD_BYTES=5242880
REQUEST_TIMEOUT_SECONDS=30
TOOL_TIMEOUT_SECONDS=10
LLM_TIMEOUT_SECONDS=30
MAX_TOOL_CALLS_PER_RUN=10
MAX_RETRIEVAL_RESULTS=10
MAX_EVAL_CASES=25
AGNO_ENABLED=true
AGNO_MODEL=mock-agno-agent
AGNO_ALLOW_REAL_PROVIDER=false
